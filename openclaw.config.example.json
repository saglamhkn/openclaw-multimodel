{
  "environments": {
    "dev": {
      "models": {
        "primary": "docker-model-runner/qwen3-coder:65k",
        "fallback": []
      },
      "docker-model-runner": {
        "base-model": "qwen3-coder:32k",
        "context-size": 65536,
        "keep-alive": -1
      },
      "mcp": {
        "servers": {
          "github": {
            "enabled": true,
            "type": "stdio",
            "command": "npx",
            "args": ["-y", "@modelcontextprotocol/server-github"],
            "env": {
              "GITHUB_PERSONAL_ACCESS_TOKEN": "${keys.github}"
            }
          }
        }
      },
      "skills": {
        "web-search": { "enabled": false },
        "screenshot": { "enabled": false },
        "memory": { "enabled": false }
      }
    },
    "beta": {
      "models": {
        "primary": "google/gemini-2.5-flash",
        "fallback": ["google/gemini-2.5-pro"]
      },
      "mcp": {
        "servers": {}
      },
      "skills": {}
    },
    "prod": {
      "models": {
        "primary": "google/gemini-2.5-flash",
        "fallback": ["google/gemini-2.5-pro"]
      },
      "mcp": {
        "servers": {
          "github": {
            "enabled": true,
            "type": "stdio",
            "command": "npx",
            "args": ["-y", "@modelcontextprotocol/server-github"],
            "env": {
              "GITHUB_PERSONAL_ACCESS_TOKEN": "${keys.github}"
            }
          }
        }
      }
    }
  },
  "keys": {
    "gemini": "",
    "anthropic": "",
    "github": ""
  },
  "agent": {
    "timeoutSeconds": 300,
    "typingIntervalSeconds": 300
  },
  "gateway": {
    "token": "changeme-generate-a-real-token",
    "port": 18789
  },
  "openclaw": {
    "image": "ghcr.io/openclaw/openclaw:latest"
  },
  "skills": {
    "installDir": "workspace"
  },
  "telegram": {
    "enabled": false,
    "token": ""
  }
}
